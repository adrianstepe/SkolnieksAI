# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# source PDFs — do not commit (large + licensing)
/data/skola2030/*.pdf
/Skola2030/

# chromadb vector database — do not commit (large, rebuilt by ingest)
/SkolnieksAI_DB/

# Python venv
/skolnieksai-env/

# Python cache
__pycache__/
*.pyc
*.pyo

# large openstax data directory
/data/openstax/

# chromadb model cache
.cache/

# local Claude Code settings
.claude/settings.local.json
