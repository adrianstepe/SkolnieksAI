# SkolnieksAI Environment Variables
# Copy to .env.local and fill in values
# NEVER commit .env.local

# --- DeepSeek (Free Tier LLM) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Anthropic (Paid Tier LLM) ---
ANTHROPIC_API_KEY=

# --- Firebase (Client — safe to expose) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase (Server — KEEP SECRET) ---
# Paste the full service account JSON as a single line
FIREBASE_SERVICE_ACCOUNT_KEY=

# --- RAG Server ---
# Shared secret between Next.js and the Python FastAPI RAG server.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
RAG_API_KEY=

# --- ChromaDB ---
CHROMA_URL=http://localhost:8001
CHROMA_COLLECTION=skola2030_chunks

# --- Chroma Cloud (leave blank to use local PersistentClient) ---
# Sign up at trychroma.com → create database "skolnieksai" → copy values below.
# Setting CHROMA_TENANT switches RAG.py and rag_server.py to cloud mode automatically.
CHROMA_TENANT=
CHROMA_DATABASE=skolnieksai
CHROMA_API_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=


BRAVE_SEARCH_API_KEY=

RESEND_API_KEY=

CRON_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used in parental consent emails for the confirmation link
NEXT_PUBLIC_BASE_URL=http://localhost:3000
