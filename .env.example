# SkolnieksAI Environment Variables
# Copy to .env.local: cp .env.example .env.local
# NEVER commit .env.local

# --- DeepSeek (Free Tier LLM) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Anthropic (Paid Tier LLM) ---
ANTHROPIC_API_KEY=

# --- Firebase (Client — safe to expose) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase (Server — KEEP SECRET) ---
FIREBASE_SERVICE_ACCOUNT_KEY=

# --- ChromaDB ---
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=skola2030_chunks

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Embedding Model ---
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
