# SkolnieksAI Environment Variables
# Copy to .env.local and fill in values
# NEVER commit .env.local

# --- DeepSeek (Free Tier LLM) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Anthropic (Paid Tier LLM) ---
ANTHROPIC_API_KEY=

# --- Firebase (Client — safe to expose) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase (Server — KEEP SECRET) ---
# Paste the full service account JSON as a single line
FIREBASE_SERVICE_ACCOUNT_KEY=

# --- RAG Server ---
# Shared secret between Next.js and the Python FastAPI RAG server.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
RAG_API_KEY=

# --- ChromaDB (local dev) ---
CHROMA_URL=http://localhost:8001
CHROMA_COLLECTION=skolnieks_content

# --- Chroma Cloud (production) ---
# Leave CHROMA_API_KEY blank → falls back to local PersistentClient at SkolnieksAI_DB/.
# Set all 4 vars in Vercel environment for production cloud mode.
# Sign up at trychroma.com → create database "skolnieksai" → copy values below.
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=skolnieksai

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_PREMIUM_ANNUAL_PRICE_ID=


BRAVE_SEARCH_API_KEY=

RESEND_API_KEY=

CRON_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used in parental consent emails for the confirmation link
NEXT_PUBLIC_BASE_URL=http://localhost:3000
